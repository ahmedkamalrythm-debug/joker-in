        .tab-btn.active { background: rgba(45,212,191,0.15); color: #2dd4bf; }
        .tab-btn:not(.active) { background: transparent; color: #475569; }
        .info-box { border-radius: 12px; padding: 14px 16px; margin-bottom: 12px; }
        .step-item { display: flex; gap: 10px; align-items: flex-start; padding: 9px 0; border-bottom: 1px solid rgba(255,255,255,0.04); }
        .step-num { min-width: 22px; height: 22px; background: linear-gradient(135deg, #2dd4bf, #0ea5e9); border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 11px; font-weight: 900; color: #050510; flex-shrink: 0; }
        .keyword-tag { display: inline-block; padding: 3px 10px; background: rgba(99,102,241,0.12); border: 1px solid rgba(99,102,241,0.25); border-radius: 20px; font-size: 11px; color: #818cf8; margin: 3px; }
        .week-label { font-size: 10px; letter-spacing: 3px; color: #2dd4bf66; font-weight: 700; padding: 16px 0 10px; }
      `}</style>

      {/* Header */}
      <div style={{
        background: "linear-gradient(180deg, rgba(45,212,191,0.08) 0%, transparent 100%)",
        padding: "40px 20px 24px",
        textAlign: "center",
        borderBottom: "1px solid rgba(255,255,255,0.05)",
      }}>
        <div style={{ fontSize: 11, color: "#2dd4bf", letterSpacing: 5, marginBottom: 10, fontWeight: 700, opacity: 0.8 }}>
          🩺 دكتور استشاري أمراض الجهاز الهضمي
        </div>
        <h1 style={{
          fontSize: "clamp(22px, 5vw, 38px)", fontWeight: 900, margin: "0 0 6px",
          background: "linear-gradient(135deg, #ffffff, #2dd4bf 60%, #0ea5e9)",
          WebkitBackgroundClip: "text", WebkitTextFillColor: "transparent", lineHeight: 1.2,
        }}>خطة المحتوى — 30 يوم</h1>
        <p style={{ color: "#475569", fontSize: 13, margin: "0 0 22px" }}>
          انقر على أي يوم للحصول على المحتوى الكامل، خطوات التنفيذ، الـ CTA، والكلمات المفتاحية
        </p>

        <div style={{ display: "flex", justifyContent: "center", gap: 10, flexWrap: "wrap", marginBottom: 20 }}>
          {[
            { icon: "📅", label: "منشور", value: "30" },
            { icon: "🎬", label: "ريلز / فيديو", value: "11" },
            { icon: "🎠", label: "كاروسيل", value: "12" },
            { icon: "🧵", label: "ثريد", value: "4" },
            { icon: "🔥", label: "متوسط الفيروسية", value: "91%" },
          ].map(s => (
            <div key={s.label} style={{
              background: "rgba(45,212,191,0.06)", border: "1px solid rgba(45,212,191,0.15)",
              borderRadius: 12, padding: "10px 14px", textAlign: "center", minWidth: 75
            }}>
              <div style={{ fontSize: 15 }}>{s.icon}</div>
              <div style={{ fontSize: 17, fontWeight: 900, color: "#2dd4bf" }}>{s.value}</div>
              <div style={{ fontSize: 9, color: "#475569", marginTop: 1 }}>{s.label}</div>
            </div>
          ))}
        </div>

        <div style={{ display: "flex", gap: 8, justifyContent: "center", flexWrap: "wrap" }}>
          {formats.map(f => (
            <button key={f} className={`filter-btn ${filter === f ? "active" : ""}`} onClick={() => setFilter(f)}>
              {formatIcons[f] || "📌"} {f}
            </button>
          ))}
        </div>
      </div>

      {/* Grid */}
      <div style={{ padding: "18px 14px", maxWidth: 1120, margin: "0 auto" }}>
        {[0, 1, 2, 3].map(week => {
          const weekDays = filtered.filter(d => Math.floor((d.day - 1) / 7) === week);
          if (!weekDays.length) return null;
          return (
            <div key={week} style={{ marginBottom: 18 }}>
              <div className="week-label">◆ الأسبوع {week + 1}</div>
              <div style={{ display: "grid", gridTemplateColumns: "repeat(auto-fill, minmax(185px, 1fr))", gap: 10 }}>
                {weekDays.map(d => {
                  const fc = formatColors[d.format] || "#94a3b8";
                  return (
                    <div key={d.day} className={`day-card ${selected?.day === d.day ? "active" : ""}`}
                      onClick={() => { setSelected(d); setTab("overview"); }}>
                      <div style={{ display: "flex", justifyContent: "space-between", alignItems: "flex-start", marginBottom: 7 }}>
                        <span style={{ fontSize: 10, fontWeight: 900, color: "#050510", background: "linear-gradient(135deg,#2dd4bf,#0ea5e9)", borderRadius: 6, padding: "2px 8px" }}>يوم {d.day}</span>
                        <span style={{ fontSize: 10, fontWeight: 700, color: fc, background: `${fc}15`, borderRadius: 6, padding: "2px 8px", border: `1px solid ${fc}35` }}>
                          {formatIcons[d.format]} {d.format}
                        </span>
                      </div>
                      <div style={{ fontSize: 10, color: "#475569", marginBottom: 3, fontWeight: 600 }}>{d.theme}</div>
                      <div style={{ fontSize: 12, fontWeight: 700, color: "#e2e8f0", marginBottom: 7, lineHeight: 1.45 }}>{d.topic}</div>
                      <div style={{ fontSize: 10, color: "#334155", marginBottom: 6 }}>🕐 {d.time} &nbsp;·&nbsp; 📱 {d.platform?.split("+")[0].trim()}</div>
                      <div className="viral-bar">
                        <div className="viral-fill" style={{
                          width: `${d.viral}%`,
                          background: d.viral >= 93 ? "linear-gradient(90deg,#f59e0b,#ef4444)" : d.viral >= 88 ? "linear-gradient(90deg,#2dd4bf,#3b82f6)" : "linear-gradient(90deg,#6366f1,#8b5cf6)"
                        }} />
                      </div>
                      <div style={{ fontSize: 9, color: "#1e293b", marginTop: 3, display: "flex", justifyContent: "space-between" }}>
                        <span>فيروسية</span>
                        <span style={{ fontWeight: 800, color: d.viral >= 93 ? "#f59e0b88" : "#2dd4bf55" }}>{d.viral}%</span>
                      </div>
                    </div>
                  );
                })}
              </div>
            </div>
          );
        })}
      </div>

      {/* Modal */}
      {selected && (
        <div className="modal-overlay" onClick={() => setSelected(null)}>
          <div className="modal" onClick={e => e.stopPropagation()}>

            <div style={{ display: "flex", justifyContent: "space-between", alignItems: "center", marginBottom: 14 }}>
              <div style={{ display: "flex", gap: 7, alignItems: "center", flexWrap: "wrap" }}>
                <span style={{ background: "linear-gradient(135deg,#2dd4bf,#0ea5e9)", color: "#050510", borderRadius: 8, padding: "4px 11px", fontWeight: 900, fontSize: 12 }}>يوم {selected.day}</span>
                <span style={{ background: `${formatColors[selected.format] || "#94a3b8"}18`, color: formatColors[selected.format] || "#94a3b8", border: `1px solid ${formatColors[selected.format] || "#94a3b8"}35`, borderRadius: 8, padding: "4px 10px", fontWeight: 700, fontSize: 11 }}>
                  {formatIcons[selected.format]} {selected.format}
                </span>
                <span style={{ fontSize: 10, color: "#475569", fontWeight: 600 }}>{selected.theme}</span>
              </div>
              <button onClick={() => setSelected(null)} style={{ background: "rgba(255,255,255,0.06)", border: "1px solid rgba(255,255,255,0.1)", color: "#64748b", width: 28, height: 28, borderRadius: 7, cursor: "pointer", fontSize: 15, display: "flex", alignItems: "center", justifyContent: "center" }}>×</button>
            </div>

            <h2 style={{ fontSize: 17, fontWeight: 900, color: "#f1f5f9", lineHeight: 1.4, marginBottom: 14 }}>{selected.topic}</h2>

            {/* Tabs */}
            <div style={{ display: "flex", gap: 3, marginBottom: 14, background: "rgba(255,255,255,0.03)", borderRadius: 11, padding: 3 }}>
              {[
                { id: "overview", label: "نظرة عامة" },
                { id: "content", label: "المحتوى الكامل" },
                { id: "steps", label: "خطوات التنفيذ" },
                { id: "seo", label: "SEO & CTA" },
              ].map(t => (
                <button key={t.id} className={`tab-btn ${tab === t.id ? "active" : ""}`} onClick={() => setTab(t.id)}>{t.label}</button>
              ))}
            </div>

            {tab === "overview" && (
              <div>
                <div className="info-box" style={{ background: "rgba(45,212,191,0.05)", border: "1px solid rgba(45,212,191,0.18)" }}>
                  <div style={{ fontSize: 9, color: "#2dd4bf", fontWeight: 800, marginBottom: 6, letterSpacing: 1 }}>🪝 الهوك الافتتاحي</div>
                  <p style={{ fontSize: 14, fontWeight: 700, color: "#e2e8f0", lineHeight: 1.7 }}>{selected.hook}</p>
                </div>
                <div style={{ display: "grid", gridTemplateColumns: "repeat(3,1fr)", gap: 8, marginBottom: 12 }}>
                  {[
                    { icon: "🕐", label: "أفضل وقت", val: selected.time, big: false },
                    { icon: "🔥", label: "الفيروسية", val: `${selected.viral}%`, big: true, hot: selected.viral >= 93 },
                    { icon: "📱", label: "المنصة", val: selected.platform?.split("+")[0].trim(), big: false },
                  ].map((item, i) => (
                    <div key={i} style={{ background: "rgba(255,255,255,0.04)", borderRadius: 10, padding: "10px 8px", textAlign: "center" }}>
                      <div style={{ fontSize: 17 }}>{item.icon}</div>
                      <div style={{ fontSize: 9, color: "#475569", marginTop: 3 }}>{item.label}</div>
                      <div style={{ fontWeight: item.big ? 900 : 700, fontSize: item.big ? 18 : 11, color: item.hot ? "#f59e0b" : "#e2e8f0", marginTop: 2, lineHeight: 1.3 }}>{item.val}</div>
                    </div>
                  ))}
                </div>
                <div className="info-box" style={{ background: "rgba(99,102,241,0.06)", border: "1px solid rgba(99,102,241,0.18)" }}>
                  <div style={{ fontSize: 9, color: "#818cf8", fontWeight: 800, marginBottom: 6, letterSpacing: 1 }}>💡 نصيحة المحترفين</div>
                  <p style={{ fontSize: 13, color: "#cbd5e1", lineHeight: 1.7 }}>{selected.tip}</p>
                </div>
              </div>
            )}

            {tab === "content" && (
              <div>
                <div className="info-box" style={{ background: "rgba(16,185,129,0.05)", border: "1px solid rgba(16,185,129,0.18)", marginBottom: 10 }}>
                  <div style={{ fontSize: 9, color: "#10b981", fontWeight: 800, marginBottom: 8, letterSpacing: 1 }}>📄 هيكل المحتوى الكامل</div>
                  <p style={{ fontSize: 13, color: "#cbd5e1", lineHeight: 1.85 }}>{selected.content}</p>
                </div>
                <div className="info-box" style={{ background: "rgba(245,158,11,0.05)", border: "1px solid rgba(245,158,11,0.18)" }}>
                  <div style={{ fontSize: 9, color: "#f59e0b", fontWeight: 800, marginBottom: 6, letterSpacing: 1 }}>📱 المنصات المقترحة</div>
                  <p style={{ fontSize: 13, color: "#cbd5e1", lineHeight: 1.6 }}>{selected.platform}</p>
                </div>
              </div>
            )}

            {tab === "steps" && (
              <div>
                <div style={{ fontSize: 9, color: "#2dd4bf", fontWeight: 800, marginBottom: 12, letterSpacing: 1 }}>🗂️ خطوات التنفيذ التفصيلية</div>
                {selected.steps?.map((step, i) => (
                  <div key={i} className="step-item">
                    <div className="step-num">{i + 1}</div>
                    <p style={{ fontSize: 13, color: "#cbd5e1", lineHeight: 1.7 }}>{step}</p>
                  </div>
                ))}
              </div>
            )}

            {tab === "seo" && (
              <div>
                <div className="info-box" style={{ background: "rgba(236,72,153,0.06)", border: "1px solid rgba(236,72,153,0.2)", marginBottom: 10 }}>
                  <div style={{ fontSize: 9, color: "#ec4899", fontWeight: 800, marginBottom: 8, letterSpacing: 1 }}>📣 نص الـ CTA</div>
                  <p style={{ fontSize: 14, fontWeight: 700, color: "#f9a8d4", lineHeight: 1.7 }}>{selected.cta}</p>
                </div>
                <div className="info-box" style={{ background: "rgba(99,102,241,0.06)", border: "1px solid rgba(99,102,241,0.18)" }}>
                  <div style={{ fontSize: 9, color: "#818cf8", fontWeight: 800, marginBottom: 10, letterSpacing: 1 }}>🔍 الكلمات المفتاحية والهاشتاقات</div>
                  <div>{selected.keywords?.map((kw, i) => <span key={i} className="keyword-tag">#{kw.replace(/\s+/g, "_")}</span>)}</div>
                </div>
              </div>
            )}
          </div>
        </div>
      )}
    </div>
  );
}
